---
interface Props {
  title: string;
  slug: string;
  director: string;
  year: number | null;
  spineNumber: number | null;
  posterUrl: string | null;
  pickCount: number;
}

const { title, slug, director, year, spineNumber, posterUrl, pickCount } = Astro.props;
const sub = [director, year].filter(Boolean).join(', ');
const spineLabel = spineNumber ? `#${spineNumber}` : '—';
---
<a class="idx-row idx-row--film" href={`/films/${slug}/`}>
  {posterUrl ? (
    <img src={posterUrl} alt={title} class="pv" loading="lazy" width="46" height="69" />
  ) : (
    <div class="pv pv-spine" aria-hidden="true">{spineLabel}</div>
  )}
  <span class="idx-main">
    <span class="idx-name">{title}</span>
    {sub && <span class="idx-sub">{sub}</span>}
  </span>
  <span class="idx-count">{pickCount} {pickCount === 1 ? 'pick' : 'picks'}</span>
</a>
