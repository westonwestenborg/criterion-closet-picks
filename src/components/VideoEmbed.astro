---
interface Props {
  platform: 'youtube' | 'vimeo';
  videoId: string;
  title: string;
}

const { platform, videoId, title } = Astro.props;
---
{platform === 'youtube' ? (
  <div class="video-embed">
    <button
      type="button"
      class="video-facade"
      data-video-id={videoId}
      aria-label={`Play video: ${title}`}
    >
      <img
        src={`https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`}
        alt=""
        loading="lazy"
        width="480"
        height="360"
        class="video-facade-poster"
      />
      <span class="video-facade-play" aria-hidden="true"></span>
    </button>
  </div>
) : (
  <div class="video-embed">
    <iframe
      src={`https://player.vimeo.com/video/${videoId}`}
      title={title}
      allow="autoplay; fullscreen; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>
)}

<style>
  .video-facade {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    border: none;
    background: #111;
    cursor: pointer;
    overflow: hidden;
    display: block;
  }

  .video-facade-poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* hqdefault has black letterbox bars; a slight scale hides them */
    transform: scale(1.35);
  }

  .video-facade-play {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 68px;
    height: 68px;
    transform: translate(-50%, -50%);
    background: rgba(17, 17, 17, 0.82);
    border: 1px solid rgba(255, 255, 248, 0.85);
    border-radius: 50%;
    transition: background-color 0.15s ease;
  }

  .video-facade-play::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 54%;
    transform: translate(-50%, -50%);
    border-style: solid;
    border-width: 11px 0 11px 18px;
    border-color: transparent transparent transparent #fffff8;
  }

  .video-facade:hover .video-facade-play,
  .video-facade:focus-visible .video-facade-play {
    background: #111;
  }

  @media (prefers-reduced-motion: reduce) {
    .video-facade-play {
      transition: none;
    }
  }
</style>

<script>
  function mountFacades() {
    document.querySelectorAll<HTMLButtonElement>('.video-facade').forEach((btn) => {
      if (btn.dataset.mounted) return;
      btn.dataset.mounted = 'true';
      btn.addEventListener('click', () => {
        const id = btn.dataset.videoId;
        if (!id) return;
        const wrapper = btn.closest('.video-embed');
        if (!wrapper) return;
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1`;
        iframe.title = btn.getAttribute('aria-label')?.replace(/^Play video: /, '') || '';
        iframe.allow =
          'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
        iframe.setAttribute('allowfullscreen', '');
        wrapper.replaceChildren(iframe);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', mountFacades);
  } else {
    mountFacades();
  }
</script>
