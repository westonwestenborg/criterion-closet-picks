---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getStats } from '../lib/data';

const stats = getStats();
---
<BaseLayout
  title="Data Exports"
  description="Machine-readable Markdown and JSON exports of the Criterion Closet Picks database."
  noindex={true}
>
  <div class="llm-export">
    <h1>Data Exports</h1>
    <p>
      Direct machine-readable exports of {stats.totalGuests} guests, {stats.totalFilms} films,
      and {stats.totalPicks} picks. Each record retains source links, quotes, and timestamps where available.
    </p>

    <h2>Complete database</h2>
    <p>
      <a class="download-link" href="/exports/closet-picks.md">Download Markdown</a>
    </p>

    <h2>Structured data</h2>
    <ul>
      <li><a href="/exports/guests.json">Guests JSON</a></li>
      <li><a href="/exports/films.json">Films JSON</a></li>
      <li><a href="/exports/picks.json">Picks JSON</a></li>
    </ul>

    <p>
      Agents can use <a href="/llms.txt">llms.txt</a> as a concise map of the site and its canonical resources.
    </p>
  </div>
</BaseLayout>
