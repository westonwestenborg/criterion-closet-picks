---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FilmRow from '../../components/FilmRow.astro';
import FilterPanel from '../../components/FilterPanel.astro';
import { getFilms, getAllDecades, getAllGenres } from '../../lib/data';

// Sort/group key: strip a leading article so "The Piano" files under P, and the
// client-side re-sort (which reads data-title) matches this server order.
const sortKey = (t: string) => t.replace(/^(the|a|an)\s+/i, '').toLowerCase();

const films = getFilms().sort((a, b) => sortKey(a.title).localeCompare(sortKey(b.title)));
const decades = getAllDecades();
const genres = getAllGenres();

// Group by first-letter of the article-stripped title, preserving sorted order.
const groups = new Map<string, typeof films>();
for (const film of films) {
  const letter = (sortKey(film.title).charAt(0) || '#').toUpperCase();
  if (!groups.has(letter)) groups.set(letter, []);
  groups.get(letter)!.push(film);
}
const letters = [...groups.keys()];
---
<BaseLayout title="Films" description="Browse all films from the Criterion Closet Picks series — filterable by decade and genre." ogImage="/og/films.png">
  <h1>Films</h1>
  <p>
    Every film picked from the Criterion Closet, filterable by decade and genre.
  </p>

  <section class="browse-controls browse-controls--compact" data-browse-singular="film" data-browse-plural="films" data-default-sort="title" data-default-dir="asc">
    <label class="sr-only" for="film-search">Search films</label>
    <input id="film-search" name="q" type="text" class="search-input" placeholder="Search films..." autocomplete="off" data-browse-search />

    <FilterPanel filters={decades} filterKey="decade" label="Decade" />
    <FilterPanel filters={genres} filterKey="genre" label="Genre" />

    <div class="sort-controls" role="group" aria-label="Sort films">
      <span class="filter-label">Sort:</span>
      <button type="button" class="filter-chip active" data-sort="title" data-dir="asc" aria-pressed="true">Title <span class="sort-arrow" aria-hidden="true">&#9650;</span></button>
      <button type="button" class="filter-chip" data-sort="year" data-dir="desc" aria-pressed="false">Year</button>
      <button type="button" class="filter-chip" data-sort="picks" data-dir="desc" aria-pressed="false">Most Picked</button>
    </div>

    <div class="browse-status-row">
      <p class="browse-status" data-browse-status role="status" aria-live="polite">
        {films.length} films shown
      </p>
      <button type="button" class="reset-filters" data-browse-reset hidden>Reset filters</button>
    </div>

    <nav class="ltr-rail" aria-label="Jump to letter" data-letter-rail>
      {letters.map((letter) => (
        <a class="ltr-anchor" href={`#ltr-${letter}`}>{letter}</a>
      ))}
    </nav>
  </section>

  <p class="empty-state" data-browse-empty hidden>No films match the current filters.</p>

  <div class="idx-list" data-browse-grid>
    {[...groups.entries()].map(([letter, group]) => (
      <>
        <div class="idx-letter" id={`ltr-${letter}`} data-browse-divider data-letter={letter} aria-hidden="true">{letter}</div>
        {group.map((film) => {
          const decade = film.year ? `${Math.floor(film.year / 10) * 10}s` : '';
          const genreStr = film.genres.join(',');
          return (
            <div
              data-browse-item
              data-letter={letter}
              data-decade={decade.toLowerCase()}
              data-genre={genreStr.toLowerCase()}
              data-search={`${film.title} ${film.director || ''}`.toLowerCase()}
              data-title={sortKey(film.title)}
              data-year={film.year || 0}
              data-picks={film.pick_count}
            >
              <FilmRow
                title={film.title}
                slug={film.slug}
                director={film.director}
                year={film.year}
                spineNumber={film.criterion_spine_number}
                posterUrl={film.poster_url}
                pickCount={film.pick_count}
              />
            </div>
          );
        })}
      </>
    ))}
  </div>
</BaseLayout>

<script>
  import '../../scripts/browseControls';
</script>
