---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuestPickItem from '../../components/GuestPickItem.astro';
import { getFilms, getFilmBySlug, getPicksForFilm, getGuestByName, getBoxSetInfoForFilm, getGuestBySlug, getPickedBoxSets, getBoxSetBySlug, getPicksForBoxSet, getBoxSetMemberFilms } from '../../lib/data';

export function getStaticPaths() {
  const slugs = new Set<string>();
  for (const f of getFilms()) slugs.add(f.slug);
  for (const b of getPickedBoxSets()) slugs.add(b.slug);
  return [...slugs].map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
// A handful of box-set catalog entries also leak into getFilms() (they were picked
// as an individual film too). For those, the existing film view is richer — it shows
// both the direct picks and the box-set aggregate guests — so prefer film and only
// fall back to the box-set view for slugs that would otherwise 404.
const film = getFilmBySlug(slug!);
const boxSet = film ? undefined : getBoxSetBySlug(slug!);

if (!film && !boxSet) {
  return Astro.redirect('/films/');
}

// --- Film view data (only when rendering a film) ---
const allPicks = film ? getPicksForFilm(film.slug) : [];
const directPicks = allPicks.filter(p => !p.box_set_film_count);
const boxSetPicks = allPicks.filter(p => p.box_set_film_count);
const boxSetInfo = film ? getBoxSetInfoForFilm(film.slug) : [];

// --- Box set view data (only when rendering a box set) ---
const hasQuote = (p: { quote?: string; extraction_confidence?: string }) =>
  !!(p.quote && p.quote.trim() !== '' && p.extraction_confidence !== 'none');
const bsPicks = boxSet ? getPicksForBoxSet(boxSet.slug) : [];
const bsQuotedPicks = bsPicks.filter(hasQuote);
const bsNoQuoteGuests = bsPicks.filter(p => !hasQuote(p)).map(p => p.guest).filter(Boolean);
const bsMembers = boxSet ? getBoxSetMemberFilms(boxSet.slug) : [];
const bsFilmCount = boxSet
  ? (bsPicks.find(p => p.box_set_film_count)?.box_set_film_count ?? bsMembers.length)
  : 0;

const pageTitle = film ? film.title : boxSet!.title;
const pageDescription = film
  ? (() => {
      const guestNames = allPicks.slice(0, 3).map(p => p.guest?.name).filter(Boolean);
      const namesStr = guestNames.length > 0 ? ` including ${guestNames.join(', ')}` : '';
      const genre = film.genres[0] || 'film';
      const article = /^[aeiou]/i.test(genre) ? 'an' : 'a';
      return `${film.title} (${film.year}) by ${film.director} — ${article} ${genre} picked by ${film.pick_count} Criterion Closet guests${namesStr}.`;
    })()
  : (() => {
      const names = bsPicks.slice(0, 3).map(p => p.guest?.name).filter(Boolean);
      const namesStr = names.length > 0 ? ` including ${names.join(', ')}` : '';
      const countStr = bsFilmCount > 0 ? ` (${bsFilmCount} films)` : '';
      return `${boxSet!.title}${countStr} — a Criterion box set picked by ${boxSet!.pick_count} Criterion Closet ${boxSet!.pick_count === 1 ? 'guest' : 'guests'}${namesStr}.`;
    })();
---
<BaseLayout title={pageTitle} description={pageDescription} ogImage={film ? `/og/films/${slug}.png` : undefined}>
  {film && (
  <div class="detail-page">
    <div class="detail-header">
      {film.poster_url ? (
        <img src={film.poster_url} alt={film.title} class="film-poster-large" />
      ) : film.criterion_spine_number ? (
        <div class="spine-placeholder" style="width: 185px; height: 278px; font-size: 2rem;">
          #{film.criterion_spine_number}
        </div>
      ) : null}
      <div class="detail-meta">
        <h1 style="margin-top: 0;">{film.title}</h1>
        <p class="text-secondary" style="font-size: 1.1rem; margin-bottom: 0.5rem;">
          {film.director ? `${film.director}, ${film.year}` : film.year}
        </p>
        {film.criterion_spine_number && (
          <p class="text-muted" style="font-size: 0.9rem; margin-bottom: 0.5rem;">
            Spine <span class="spine-number">#{film.criterion_spine_number}</span>
          </p>
        )}
        <p style="margin-bottom: 0.5rem;">
          <span class="badge">
            Picked by {film.pick_count} {film.pick_count === 1 ? 'guest' : 'guests'}
          </span>
        </p>
        {film.genres.length > 0 && (
          <p class="text-muted" style="font-size: 0.85rem; margin-bottom: 0.5rem;">
            {film.genres.join(' / ')}
          </p>
        )}
        {boxSetInfo.length > 0 && boxSetInfo.map((bs) => (
          <p class="text-muted" style="font-size: 0.85rem; margin-bottom: 0.5rem;">
            Part of {bs.criterion_url ? (
              <a href={bs.criterion_url} target="_blank" rel="noopener noreferrer">{bs.name}</a>
            ) : (
              <span>{bs.name}</span>
            )}
          </p>
        ))}
        <div class="detail-links">
          {film.criterion_url && (
            <a href={film.criterion_url} target="_blank" rel="noopener noreferrer">
              Criterion
            </a>
          )}
          {film.letterboxd_url && (
            <a href={film.letterboxd_url} target="_blank" rel="noopener noreferrer">
              Letterboxd
            </a>
          )}
          {film.tmdb_url && (
            <a href={film.tmdb_url} target="_blank" rel="noopener noreferrer">
              TMDB
            </a>
          )}
        </div>
      </div>
    </div>

    {film.credits && (
      <div class="film-credits">
        {film.credits.directors.length > 0 && (
          <p>
            <span class="credit-label">Directed by</span>{' '}
            {film.credits.directors.map((d, i) => {
              const guest = getGuestByName(d.name);
              return (
                <>
                  {i > 0 && ', '}
                  {guest ? <a href={`/guests/${guest.slug}/`}>{d.name}</a> : d.name}
                </>
              );
            })}
          </p>
        )}
        {film.credits.writers.length > 0 && (
          <p>
            <span class="credit-label">Written by</span>{' '}
            {film.credits.writers.map((w, i) => {
              const guest = getGuestByName(w.name);
              return (
                <>
                  {i > 0 && ', '}
                  {guest ? <a href={`/guests/${guest.slug}/`}>{w.name}</a> : w.name}
                </>
              );
            })}
          </p>
        )}
        {film.credits.cinematographers.length > 0 && (
          <p>
            <span class="credit-label">Cinematography</span>{' '}
            {film.credits.cinematographers.map((c, i) => {
              const guest = getGuestByName(c.name);
              return (
                <>
                  {i > 0 && ', '}
                  {guest ? <a href={`/guests/${guest.slug}/`}>{c.name}</a> : c.name}
                </>
              );
            })}
          </p>
        )}
        {film.credits.editors.length > 0 && (
          <p>
            <span class="credit-label">Edited by</span>{' '}
            {film.credits.editors.map((e, i) => {
              const guest = getGuestByName(e.name);
              return (
                <>
                  {i > 0 && ', '}
                  {guest ? <a href={`/guests/${guest.slug}/`}>{e.name}</a> : e.name}
                </>
              );
            })}
          </p>
        )}
        {film.credits.cast.length > 0 && (
          <p>
            <span class="credit-label">Cast</span>{' '}
            {film.credits.cast.map((c, i) => {
              const guest = getGuestByName(c.name);
              return (
                <>
                  {i > 0 && ', '}
                  {guest ? <a href={`/guests/${guest.slug}/`}>{c.name}</a> : c.name}
                </>
              );
            })}
          </p>
        )}
      </div>
    )}

    <h2>Picked by</h2>

    <div class="picks-list">
      {directPicks.map((pick) => <GuestPickItem pick={pick} />)}
    </div>

    {boxSetInfo.map((bs) => {
      const bsPicks = boxSetPicks.filter(p => p.box_set_name === bs.name);
      const noQuoteGuests = bs.guest_slugs.map(s => getGuestBySlug(s)).filter(Boolean);
      const totalBoxSetGuests = bsPicks.length + bs.guest_count;
      return totalBoxSetGuests > 0 ? (
        <div style="margin-top: 2rem;">
          <h3 style="font-size: 1.1rem;">
            Also mentioned as part of {bs.criterion_url ? (
              <a href={bs.criterion_url} target="_blank" rel="noopener noreferrer">{bs.name}</a>
            ) : bs.name}
          </h3>
          {bsPicks.length > 0 && (
            <div class="picks-list">
              {bsPicks.map((pick) => <GuestPickItem pick={pick} />)}
            </div>
          )}
          {noQuoteGuests.length > 0 && (
            <details class="box-set-details" style="margin-top: 0.5rem;">
              <summary class="text-muted">
                {bs.guest_count} more {bs.guest_count === 1 ? 'guest' : 'guests'} picked this box set without comment
              </summary>
              <ul class="box-set-film-list" style="margin-top: 0.5rem;">
                {noQuoteGuests.map((g) => (
                  <li><a href={`/guests/${g!.slug}/`}>{g!.name}</a></li>
                ))}
              </ul>
            </details>
          )}
        </div>
      ) : null;
    })}
  </div>
  )}

  {boxSet && (
  <div class="detail-page">
    <div class="detail-header">
      {boxSet.poster_url && (
        <img src={boxSet.poster_url} alt={boxSet.title} class="film-poster-large" />
      )}
      <div class="detail-meta">
        <h1 style="margin-top: 0;">{boxSet.title}</h1>
        <p class="text-muted" style="font-size: 0.9rem; margin-bottom: 0.5rem;">
          Box set{bsFilmCount > 0 ? ` · ${bsFilmCount} films` : ''}
        </p>
        <p style="margin-bottom: 0.5rem;">
          <span class="badge">
            Picked by {boxSet.pick_count} {boxSet.pick_count === 1 ? 'guest' : 'guests'}
          </span>
        </p>
        <div class="detail-links">
          {boxSet.criterion_url && (
            <a href={boxSet.criterion_url} target="_blank" rel="noopener noreferrer">
              View on Criterion
            </a>
          )}
          {boxSet.tmdb_url && (
            <a href={boxSet.tmdb_url} target="_blank" rel="noopener noreferrer">
              TMDB
            </a>
          )}
        </div>
      </div>
    </div>

    {bsMembers.length > 0 && (
      <div style="margin-top: 1.5rem;">
        <h2>Films in this set</h2>
        <ul class="box-set-film-list">
          {bsMembers.map((m) => (
            <li>
              {m.film ? (
                <a href={`/films/${m.film.slug}/`}>{m.title}</a>
              ) : (
                <span>{m.title}</span>
              )}
            </li>
          ))}
        </ul>
      </div>
    )}

    <h2>Picked by</h2>

    <div class="picks-list">
      {bsQuotedPicks.map((pick) => <GuestPickItem pick={pick} />)}
    </div>

    {bsNoQuoteGuests.length > 0 && (
      <p class="text-muted" style="margin-top: 1rem;">
        Also picked by{' '}
        {bsNoQuoteGuests.map((g, i) => (
          <>
            {i > 0 && ', '}
            <a href={`/guests/${g!.slug}/`}>{g!.name}</a>
          </>
        ))}
      </p>
    )}
  </div>
  )}
</BaseLayout>
