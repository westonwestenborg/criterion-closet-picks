---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuestCard from '../../components/GuestCard.astro';
import FilterPanel from '../../components/FilterPanel.astro';
import { getPublishableGuests, getAllProfessions } from '../../lib/data';

const guests = getPublishableGuests().sort((a, b) => a.name.localeCompare(b.name));
const professions = getAllProfessions();
---
<BaseLayout title="Guests" description="Browse all Criterion Closet Picks guests — directors, actors, musicians, and more." ogImage="/og/guests.png">
  <h1>Guests</h1>
  <p>
    Every guest who has visited the Criterion Closet, filterable by profession.
  </p>

  <section class="browse-controls" data-browse-singular="guest" data-browse-plural="guests">
    <label class="sr-only" for="guest-search">Search guests</label>
    <input id="guest-search" name="q" type="text" class="search-input" placeholder="Search guests..." autocomplete="off" data-browse-search />

    <FilterPanel filters={professions} filterKey="profession" label="Profession" />

    <div class="browse-status-row">
      <p class="browse-status" data-browse-status role="status" aria-live="polite">
        {guests.length} guests shown
      </p>
      <button type="button" class="reset-filters" data-browse-reset hidden>Reset filters</button>
    </div>
  </section>

  <p class="empty-state" data-browse-empty hidden>No guests match the current filters.</p>

  <div class="grid" data-browse-grid>
    {guests.map((guest) => (
      <div data-profession={guest.profession} data-search={guest.name.toLowerCase()}>
        <GuestCard
          name={guest.name}
          slug={guest.slug}
          profession={guest.profession}
          photoUrl={guest.photo_url}
          pickCount={guest.pick_count}
        />
      </div>
    ))}
  </div>
</BaseLayout>

<script>
  import '../../scripts/browseControls';
</script>
