---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PickItem from '../../components/PickItem.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import { getGuestBySlug, getDisplayablePicksForGuest, getPublishableGuests } from '../../lib/data';
import type { Pick, Film, GuestVisit } from '../../lib/data';

export function getStaticPaths() {
  const guests = getPublishableGuests();
  return guests.map((guest) => ({
    params: { slug: guest.slug },
  }));
}

const { slug } = Astro.params;
const guest = getGuestBySlug(slug!);

if (!guest) {
  return Astro.redirect('/guests/');
}

const picks = getDisplayablePicksForGuest(guest.slug);

const episodeYear = guest.episode_date ? new Date(guest.episode_date).getFullYear() : null;

// Multi-visit support
const visits = guest.visits ?? [];
const isMultiVisit = visits.length >= 2;

// Group picks by visit_index for multi-visit guests
type PickWithFilm = Pick & { film: Film | undefined };
const visitGroups: Map<number, PickWithFilm[]> = new Map();
if (isMultiVisit) {
  for (const pick of picks) {
    const vi = pick.visit_index ?? 1;
    if (!visitGroups.has(vi)) visitGroups.set(vi, []);
    visitGroups.get(vi)!.push(pick);
  }
} else {
  visitGroups.set(1, picks);
}
// Gather all unique links from visits (or fall back to top-level)
const allCriterionUrls = isMultiVisit
  ? visits.map(v => v.criterion_page_url).filter(Boolean) as string[]
  : [guest.criterion_page_url].filter(Boolean) as string[];

// Helper to render a single pick entry
function getVideoEmbed(visit: GuestVisit, label: string, guestName: string) {
  if (visit.youtube_video_id) {
    return { type: 'youtube' as const, id: visit.youtube_video_id, title: `${guestName} - ${label}` };
  }
  if (visit.vimeo_video_id) {
    return { type: 'vimeo' as const, id: visit.vimeo_video_id, title: `${guestName} - ${label}` };
  }
  return null;
}

const filmNames = picks.filter(p => p.film && !p.box_set_film_count).slice(0, 3).map(p => p.film!.title);
const namesStr = filmNames.length > 0 ? ` — including ${filmNames.join(', ')}` : '';
const pageDescription = `Hear what ${guest.name} has to say about ${picks.length > 1 ? `${picks.length} picks` : '1 pick'} from the Criterion Closet${namesStr}.`;
const pageUrl = new URL(`/guests/${slug}/`, Astro.site).href;
const entityType = guest.guest_type === 'group' ? 'Organization' : guest.guest_type === 'person' || !guest.guest_type ? 'Person' : 'Thing';
const mainEntity = {
  '@type': entityType,
  name: guest.name,
  url: pageUrl,
  ...(entityType === 'Person' ? { jobTitle: guest.profession } : { description: guest.profession }),
  ...(guest.photo_url ? { image: guest.photo_url } : {}),
};
const videoSources = visits.length > 0
  ? visits
  : [{
      youtube_video_id: guest.youtube_video_id,
      youtube_video_url: guest.youtube_video_url,
      vimeo_video_id: guest.vimeo_video_id,
      episode_date: guest.episode_date,
      criterion_page_url: guest.criterion_page_url,
    }];
const videoSchemas = videoSources
  .filter((visit) => visit.youtube_video_id)
  .map((visit, index) => ({
    '@context': 'https://schema.org',
    '@type': 'VideoObject',
    name: `${guest.name} visits the Criterion Closet${videoSources.length > 1 ? ` — Visit ${index + 1}` : ''}`,
    description: pageDescription,
    thumbnailUrl: `https://i.ytimg.com/vi/${visit.youtube_video_id}/hqdefault.jpg`,
    ...(visit.episode_date ? { uploadDate: new Date(visit.episode_date).toISOString() } : {}),
    embedUrl: `https://www.youtube.com/embed/${visit.youtube_video_id}`,
    contentUrl: visit.youtube_video_url || `https://www.youtube.com/watch?v=${visit.youtube_video_id}`,
  }));
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    name: `${guest.name} — Closet Picks`,
    url: pageUrl,
    description: pageDescription,
    mainEntity,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Closet Picks', item: Astro.site!.href },
      { '@type': 'ListItem', position: 2, name: 'Guests', item: new URL('/guests/', Astro.site).href },
      { '@type': 'ListItem', position: 3, name: guest.name, item: pageUrl },
    ],
  },
  ...videoSchemas,
];
---
<BaseLayout title={guest.name} description={pageDescription} ogImage={`/og/guests/${slug}.png`} ogType={entityType === 'Person' ? 'profile' : 'website'} structuredData={structuredData}>
  <div class="detail-page">
    <div class="detail-header">
      {guest.photo_url ? (
        <img src={guest.photo_url} alt={guest.name} class="guest-photo" style="width: 120px; height: 120px;" />
      ) : (
        <div class="guest-initial" style="width: 120px; height: 120px; font-size: 3rem;">
          {guest.name.charAt(0)}
        </div>
      )}
      <div class="detail-meta">
        <h1 style="margin-top: 0;">{guest.name}</h1>
        <p class="small-caps text-secondary" style="margin-bottom: 0.5rem;">
          {guest.profession}
        </p>
        {episodeYear && (
          <p class="text-muted" style="font-size: 0.9rem; margin-bottom: 0.5rem;">
            Aired {episodeYear}
          </p>
        )}
        <div class="detail-links">
          {picks.length > 0 && (
            <a href="#picks">
              View {picks.length} {picks.length === 1 ? 'Pick' : 'Picks'}
            </a>
          )}
          {!isMultiVisit && (guest.youtube_video_url ? (
            <a href={guest.youtube_video_url} target="_blank" rel="noopener noreferrer">
              Full Video
            </a>
          ) : guest.vimeo_video_id ? (
            <a href={`https://vimeo.com/${guest.vimeo_video_id}`} target="_blank" rel="noopener noreferrer">
              Full Video
            </a>
          ) : null)}
          {allCriterionUrls.map((url, i) => (
            <a href={url} target="_blank" rel="noopener noreferrer">
              {allCriterionUrls.length > 1 ? `Criterion (Visit ${i + 1})` : 'Criterion Page'}
            </a>
          ))}
        </div>
      </div>
    </div>

    {isMultiVisit ? (
      /* Multi-visit layout: group by visit with separate video + picks per visit */
      visits.map((visit, idx) => {
        const vi = idx + 1;
        const visitPicks = visitGroups.get(vi) || [];
        if (visitPicks.length === 0) return null;
        const visitYear = visit?.episode_date ? new Date(visit.episode_date).getFullYear() : null;
        const label = visitYear ? `Visit ${vi} (${visitYear})` : `Visit ${vi}`;
        const embed = getVideoEmbed(visit, label, guest.name);

        return (
          <div class="visit-section">
            <h2 id={idx === 0 ? 'picks' : undefined}>{label} &mdash; {visitPicks.length} Picks</h2>
            {embed && <VideoEmbed platform={embed.type} videoId={embed.id} title={embed.title} />}
            {visitPicks.length > 0 && (
              <div class="picks-list">
                {visitPicks.map((pick) => <PickItem pick={pick} />)}
              </div>
            )}
          </div>
        );
      })
    ) : (
      /* Single-visit layout */
      <Fragment>
        {guest.youtube_video_id ? (
          <VideoEmbed platform="youtube" videoId={guest.youtube_video_id} title={`${guest.name} - Criterion Closet Picks`} />
        ) : guest.vimeo_video_id ? (
          <VideoEmbed platform="vimeo" videoId={guest.vimeo_video_id} title={`${guest.name} - Criterion Closet Picks`} />
        ) : null}

        <h2 id="picks">{picks.length} Picks</h2>

        {picks.length > 0 && (
          <div class="picks-list">
            {picks.map((pick) => <PickItem pick={pick} />)}
          </div>
        )}

        {picks.length === 0 && (
          <p class="text-muted">No picks data available for this guest.</p>
        )}
      </Fragment>
    )}
  </div>
</BaseLayout>
