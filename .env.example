# TMDB API (https://www.themoviedb.org/settings/api)
# Register for free at https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN=<your-tmdb-read-access-token>
TMDB_API_KEY=<your-tmdb-api-key>

# Google AI / Gemini (https://aistudio.google.com/apikey)
# Used for transcript quote extraction via Gemini 2.0 Flash
GEMINI_API_KEY=<your-gemini-api-key>

# X/Twitter API v2 (https://developer.x.com/en/portal/dashboard)
# OAuth 1.0a credentials for posting tweets
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Threads / Meta Graph API (https://developers.facebook.com/)
# OAuth 2.0 long-lived token (60-day expiry, auto-refreshed by script)
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_TOKEN_CREATED=  # ISO date, e.g. 2026-03-10 (updated by script on refresh)

# YouTube Data API v3 (https://console.cloud.google.com/apis/credentials)
# Used by backfill_dates.py to fetch video upload dates
YOUTUBE_API_KEY=
